# LLM keys
GROQ_API_KEY=
FIREWORKS_API_KEY=
BASETEN_API_KEY=
GITHUB_TOKEN=

# Model config
GROQ_MODEL=llama-3.1-8b-instant
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m2p5
BASETEN_MODEL=openai/gpt-oss-120b
CONSOLIDATION_MODEL=gpt-4o
CONSOLIDATION_PROVIDER=github

# Generation strategy
GENERATION_PROVIDERS=fireworks,groq,baseten
MIN_SUCCESS_MODELS=2
GENERATION_CHUNK_SIZE=30
GROQ_MAX_TOKENS=12000
FIREWORKS_MAX_TOKENS=24576
BASETEN_MAX_TOKENS=8192
CONSOLIDATION_MAX_TOKENS=8192
PROVIDER_RATE_LIMIT_RETRIES=3
PROVIDER_RATE_LIMIT_BASE_DELAY_SEC=1.5
PROVIDER_COOLDOWN_SEC=90

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=innovex-lc
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=innovex-lc

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
MAX_CONCURRENT_RUNS=2
RUN_STORE_JSONL_PATH=output/pipeline_runs.jsonl
RUN_STORE_MEMORY_LIMIT=2000
